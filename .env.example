# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your actual keys.

# ── LLM providers (Ecommerce AI series) ───────────────────────────────────────
# OpenAI is used for LLM answer generation only. Embeddings run locally via sentence-transformers (no API key needed for embeddings).
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── pgvector (Ecommerce AI series) ────────────────────────────────────────────
# Postgres + pgvector for the RAG vector store. Start it with: docker compose up -d
DATABASE_URL=postgresql://playbooks:playbooks@localhost:5432/playbooks
